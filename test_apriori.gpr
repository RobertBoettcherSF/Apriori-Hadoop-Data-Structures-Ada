-- test_apriori.gpr
-- GNAT Project file for Apriori algorithm test suite
--
-- This GNAT Project file defines the build configuration for the test suite
-- executable. It compiles all Ada source files including the test procedures
-- and links them into a single test executable.
--
-- Usage:
--   mkdir obj
--   gprbuild -P test_apriori.gpr
--   ./test_apriori

project Test_Apriori is

   -- Source directory: where to find Ada source files
   for Source_Dirs use (".");

   -- Object directory: where to store compiled object files
   for Object_Dir use "obj";

   -- Executable directory: where to place the final executable
   for Exec_Dir use ".";

   -- Main source file: entry point for the test executable
   for Main use ("test_apriori.adb");

   -- Compiler switches: optimization level
   -- -O2: Enable optimizations for better performance
   package Compiler is
      for Default_Switches ("Ada") use ("-O2");
   end Compiler;

   -- Binder switches: static linking
   -- -E: Static linking (default for executables)
   package Binder is
      for Switches ("Ada") use ("-E");
   end Binder;

end Test_Apriori;
